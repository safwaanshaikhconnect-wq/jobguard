# === FRONTEND (Gemini fallback) ===
# Used by the frontend when the backend is offline
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# === BACKEND (backend/.env) ===
# Primary LLM for job analysis, chat, and OSINT search
GROQ_API_KEY="gsk_YOUR_GROQ_API_KEY"

# HuggingFace Inference API for the secondary ML classifier
HF_API_KEY="hf_YOUR_HUGGINGFACE_API_KEY"

# VirusTotal API for URL threat scanning
VT_API_KEY="YOUR_VIRUSTOTAL_API_KEY"

# APP_URL: The URL where this applet is hosted (optional, for deployment)
APP_URL="http://localhost:3000"
