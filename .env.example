# =========================================================================
# FRONTEND CONFIGURATION (Add these to Vercel Environment Variables)
# =========================================================================
# The URL of your deployed backend (e.g., https://your-backend.herokuapp.com)
# Leave blank to default to http://localhost:8000 for local testing
VITE_API_URL=""

# Google Gemini API key for the cloud fallback analysis
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# AI Studio App URL (Optional)
VITE_APP_URL="http://localhost:3000"


# =========================================================================
# BACKEND CONFIGURATION
# =========================================================================
# Primary LLM for job analysis, chat, and OSINT search
GROQ_API_KEY="gsk_YOUR_GROQ_API_KEY"

# HuggingFace Inference API for the secondary ML classifier
HF_API_KEY="hf_YOUR_HUGGINGFACE_API_KEY"

# VirusTotal API for URL threat scanning
VT_API_KEY="YOUR_VIRUSTOTAL_API_KEY"
